# Copy to deploy.env and fill in real values before deployment.
# Usage:
#   cp deploy.env.example deploy.env
#   set -a
#   . ./deploy.env
#   set +a
#   ./openclaw-deploy.sh

# Optional: override the default release name prompt
# RELEASE_NAME="openclaw"

# Required for Bedrock access
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"

# Optional for temporary AWS credentials
# AWS_SESSION_TOKEN="YOUR_AWS_SESSION_TOKEN"

# Required for Microsoft Graph delegated login plugin
MSGRAPH_TENANT_ID="YOUR_MICROSOFT_ENTRA_TENANT_ID"
MSGRAPH_CLIENT_ID="YOUR_MICROSOFT_GRAPH_APP_CLIENT_ID"

# Optional: overrides the default Jira tenant URL used by jira-query
# JIRA_BASE_URL="https://dame-technologies.atlassian.net/"

# Optional: named pod-delegate targets rendered directly into openclaw.json.
# Targets should point at gateways that expose POST /v1/responses with bearer auth and have
# gateway.http.endpoints.responses.enabled turned on.
# Example:
# POD_DELEGATE_TARGETS_JSON='{"openclaw-b":{"token":"replace-with-gateway-token"}}'

# OpenClaw always expects the shared in-cluster Ollama embeddings service at
# http://ollama-embeddings.openclaw.svc.cluster.local:11434 for semantic memory search.
# Deploy the actual Ollama pod separately with ./deploy-ollama-embeddings.sh.
# OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text
