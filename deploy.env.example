# Copy to deploy.env and fill in real values before deployment.
# Usage:
#   cp deploy.env.example deploy.env
#   set -a
#   . ./deploy.env
#   set +a
#   ./openclaw-deploy.sh

# Optional: override the default release name prompt
# RELEASE_NAME="openclaw"

# Required for Bedrock access
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"

# Optional for temporary AWS credentials
# AWS_SESSION_TOKEN="YOUR_AWS_SESSION_TOKEN"

# Required for Microsoft Graph delegated login plugin
MSGRAPH_TENANT_ID="YOUR_MICROSOFT_ENTRA_TENANT_ID"
MSGRAPH_CLIENT_ID="YOUR_MICROSOFT_GRAPH_APP_CLIENT_ID"
