# Shared OpenClaw wildcard edge configuration
# Copy this file to terraform.tfvars and fill in your actual values.

aws_region  = "ap-southeast-2"
aws_profile = "personal"
environment = "prod"

# Existing shared ALB
existing_alb_name = "openclaw-alb"
existing_https_listener_port = 443

# Private ingress-nginx endpoint(s) reachable from the ALB VPC/VPN
ingress_target_ips = [
  "10.42.32.210",
]

# Route53 / ACM wildcard certificate
route53_zone_name = "dametech.net"
wildcard_domain_name = "*.openclaw.dametech.net"
